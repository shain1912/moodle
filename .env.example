# ===== 서버 =====
PORT=3000
NODE_ENV=development
# 운영(HTTPS)에서는 true 로 변경 — 쿠키 secure 플래그
COOKIE_SECURE=false

# ===== Supabase (DB/명단/진도 저장) =====
# Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role(또는 secret) key — ⚠️ 절대 외부 노출 금지 (서버 전용)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ===== Cloudflare R2 (영상 저장/스트리밍, egress 무료) =====
# Cloudflare 대시보드 → R2 → "Manage R2 API Tokens" 에서 발급
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=lectures
# 업로드 서명 URL 유효시간(초) — 대용량 업로드 대비 넉넉히 (기본 6시간)
R2_UPLOAD_TTL=21600

# ===== 보안 =====
# 긴 랜덤 문자열. 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please-change-this-to-a-long-random-string

# ===== 관리자(교사) 최초 계정 — 첫 실행 시 자동 생성 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=관리자

# ===== 진도 정책 =====
# 완료 인정 기준 (시청 비율 %)
COMPLETION_THRESHOLD=90
# 재생용 서명 URL 유효시간(초)
SIGNED_PLAY_TTL=7200
